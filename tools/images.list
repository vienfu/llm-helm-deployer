# 镜像清单：方案 B（mirror-images.sh）与方案 C（build-bundle.sh）共享。
# 一行一个镜像，含 registry/path:tag。'#' 开头为注释，空行忽略。
# 升级子 chart 版本时同步更新此文件。

# 主 chart
docker.io/vllm/vllm-openai:v0.6.3
docker.io/curlimages/curl:8.10.1

# nvidia-device-plugin 0.17.0 (AppVersion 对齐)
nvcr.io/nvidia/k8s-device-plugin:v0.17.0

# dcgm-exporter 3.4.2 (AppVersion 对齐)
nvcr.io/nvidia/k8s/dcgm-exporter:3.3.5-3.4.0-ubuntu22.04

# prometheus 25.27.0 (单实例 Prometheus，annotation-based scrape)
# server 主镜像 + sidecar config-reloader（chart 默认注入，离线场景必须同步）
quay.io/prometheus/prometheus:v3.11.3
quay.io/prometheus-operator/prometheus-config-reloader:v0.76.0
